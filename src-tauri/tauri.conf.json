{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "cubely",
  "version": "0.1.1",
  "identifier": "com.cubely.dev",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Cubely",
        "width": 1440,
        "height": 900,
        "minWidth": 970,
        "minHeight": 615,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFCNkM1OThBRjU4NDYxMzIKUldReVlZVDFpbGxzcTlvNFh0NlFBUWJxeFJhWjRFTDF1bzhqdTI4ZGQvbm1qQUREZm5jeWcyUEMK",
      "endpoints": [
        "https://github.com/Kilaparthi-Himanshu/cubely/releases/latest/download/latest.json"
      ]
    }
  }
}
